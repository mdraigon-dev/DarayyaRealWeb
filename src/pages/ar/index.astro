---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomeContent from '../../components/HomeContent.tsx';
import { t } from '../../i18n/strings';
import { withComputedDaysLeft } from '../../data/compute-days-left';

const projects = await getCollection('projects');
const projectData = projects
  .map(p => withComputedDaysLeft(p.data))
  .sort((a, b) => a.order - b.order);

const lang = 'ar' as const;
const baseUrl = import.meta.env.BASE_URL;
const basePath = `${baseUrl}${lang}`.replace(/\/$/, ''); // /darayya-platform/ar
---

<BaseLayout
  title={`${t(lang, 'brand_title')} — ${t(lang, 'brand_sub')}`}
  description={t(lang, 'hero_tag')}
  lang={lang}
  currentPage="home"
>
  <HomeContent
    lang={lang}
    basePath={basePath}
    baseUrl={baseUrl}
    projects={projectData}
    client:load
  />
</BaseLayout>
