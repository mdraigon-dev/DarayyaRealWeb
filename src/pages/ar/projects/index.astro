---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProjectsListContent from '../../../components/ProjectsListContent.tsx';
import { t } from '../../../i18n/strings';
import { withComputedDaysLeft } from '../../../data/compute-days-left';

const projects = await getCollection('projects');
const projectData = projects.map(p => withComputedDaysLeft(p.data)).sort((a, b) => a.order - b.order);

const lang = 'ar' as const;
const baseUrl = import.meta.env.BASE_URL;
const basePath = `${baseUrl}${lang}`.replace(/\/$/, '');
---

<BaseLayout
  title={`${t(lang, 'projects_title')} — ${t(lang, 'brand_title')}`}
  description={t(lang, 'projects_desc')}
  lang={lang}
  currentPage="projects"
>
  <ProjectsListContent lang={lang} basePath={basePath} projects={projectData} client:load />
</BaseLayout>
