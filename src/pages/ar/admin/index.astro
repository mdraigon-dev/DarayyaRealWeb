---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AdminDashboard from '../../../components/AdminDashboard.tsx';
import AuthGate from '../../../components/AuthGate.tsx';
import { t } from '../../../i18n/strings';

const projects = await getCollection('projects');
const projectData = projects.map(p => p.data).sort((a, b) => a.order - b.order);

const lang = 'ar' as const;
const baseUrl = import.meta.env.BASE_URL;
const basePath = `${baseUrl}${lang}`.replace(/\/$/, '');
---

<BaseLayout
  title={`${t(lang, 'nav_admin')} — ${t(lang, 'brand_title')}`}
  description={t(lang, 'admin_desc')}
  lang={lang}
  currentPage="admin"
>
  <!-- Netlify Identity widget — provides auth used by both Decap CMS and this dashboard.
       See README for setup. -->
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js" is:inline></script>

  <!--
    Why client:only="react" instead of client:load?
    With client:load, Astro server-renders the dashboard HTML at build time,
    embedding sample donation data and other sensitive bits in the static
    HTML. The auth gate would only hide it visually, but anyone could view
    the source. With client:only, the dashboard's HTML is NEVER on the page
    until the user is authenticated client-side.

    The trade-off: visitors see the loading shell below until the JS hydrates.
  -->
  <AuthGate lang={lang} client:only="react">
    <AdminDashboard lang={lang} basePath={basePath} projects={projectData} client:only="react" />

    <!-- Loading fallback shown while React loads -->
    <div slot="fallback" class="auth-gate-screen">
      <div class="auth-gate-card">
        <div class="auth-gate-spinner"></div>
        <p style="color: var(--sy-muted); margin-top: 1rem;">{t(lang, 'auth_loading')}</p>
      </div>
    </div>
  </AuthGate>
</BaseLayout>
