---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AdminDashboard from '../../../components/AdminDashboard.tsx';
import { t } from '../../../i18n/strings';

const projects = await getCollection('projects');
const projectData = projects.map(p => p.data).sort((a, b) => a.order - b.order);

const lang = 'ar' as const;
const baseUrl = import.meta.env.BASE_URL;
const basePath = `${baseUrl}${lang}`.replace(/\/$/, '');
---

<BaseLayout
  title={`${t(lang, 'nav_admin')} — ${t(lang, 'brand_title')}`}
  description={t(lang, 'admin_desc')}
  lang={lang}
  currentPage="admin"
>
  {/*
    Per user request: AuthGate removed. Dashboard is now publicly viewable.
    Editing actions still require Decap CMS login at /admin/.

    NOTE: Sensitive data (donor names, amounts, alert notes) used to be hidden
    behind auth. Now they will be visible to anyone with the dashboard URL.
    Current data is sample/illustrative; when v2 adds real donations, revisit
    this decision so real financial info isn't exposed.
  */}
  <AdminDashboard lang={lang} basePath={basePath} projects={projectData} client:load />
</BaseLayout>
