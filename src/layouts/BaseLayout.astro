---
// Base layout for all pages.
// Sets the language/direction, loads fonts, Leaflet, and global styles.
// Renders nav and footer, with a slot for page content.

import '../styles/global.css';
import Nav from '../components/Nav.tsx';
import Footer from '../components/Footer.tsx';
// Vite's ?raw suffix inlines the file contents as a string at build time
import symbolHtml from '../components/_logo_symbol.html.txt?raw';

interface Props {
  title: string;
  description?: string;
  lang: 'ar' | 'en';
  currentPage?: 'home' | 'projects' | 'transparency' | 'admin';
}

const { title, description, lang, currentPage = 'home' } = Astro.props;
const dir = lang === 'ar' ? 'rtl' : 'ltr';
---

<!DOCTYPE html>
<html lang={lang} dir={dir}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#00582C" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}

  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}logos/darayya-emblem.svg`} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Markazi+Text:wght@400;500;600;700&family=Lora:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
          integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin="" is:inline></script>

  <!-- Netlify Identity widget — loaded site-wide so logged-in staff see
       "Add note" and "Edit" affordances on project pages. Auto-detects
       API URL because the site is hosted on Netlify. Anonymous visitors
       see nothing — the widget is invisible until openIdentity() is called. -->
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js" is:inline></script>
</head>
<body>
  <!-- Inline SVG symbol for the Darayya logo, used via <use> -->
  <Fragment set:html={symbolHtml} />

  <Nav lang={lang} currentPage={currentPage} client:load />

  <main>
    <slot />
  </main>

  <Footer lang={lang} client:load />
</body>
</html>
